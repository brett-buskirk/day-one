{
  "name": "day-one",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Day One — a phone-first reentry simulator (React PWA).",
  "scripts": {
    "build:content": "node scripts/build-content.mjs",
    "icons": "node scripts/make-icons.mjs",
    "predev": "npm run build:content",
