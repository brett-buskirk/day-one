    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.20.0",
    "js-yaml": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6"
